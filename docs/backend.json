{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Auth."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        },
        "gender": {
          "type": "string",
          "description": "The user's gender.",
          "enum": ["男", "女", "其他", "保密"]
        },
        "location": {
            "type": "string",
            "description": "The user's city."
        },
        "bio": {
          "type": "string",
          "description": "The user's personal biography or introduction."
        },
        "kycStatus": {
          "type": "string",
          "description": "The user's KYC verification status.",
          "enum": ["Not Verified", "Pending", "Verified"]
        },
        "createdAt": {
            "type": "string", 
            "format": "date-time"
        },
        "lastLogin": {
            "type": "string", 
            "format": "date-time"
        },
        "rating": {
          "type": "number",
          "description": "The user's average rating out of 5."
        },
        "reviewsCount": {
          "type": "number",
          "description": "Total number of reviews the user has received."
        },
        "salesCount": {
          "type": "number",
          "description": "Total number of items sold by the user."
        },
        "purchasesCount": {
          "type": "number",
          "description": "Total number of items purchased by the user."
        },
        "followersCount": {
          "type": "number",
          "description": "The number of users following this user."
        },
        "followingCount": {
          "type": "number",
          "description": "The number of users this user is following."
        },
        "creditScore": {
          "type": "number",
          "description": "A calculated score representing user's trustworthiness."
        },
        "creditLevel": {
          "type": "string",
          "description": "The user's credit level.",
          "enum": ["Newcomer", "Bronze", "Silver", "Gold", "Platinum", "Diamond"]
        },
        "lunarSoil": {
          "type": "number",
          "description": "The user's balance of Lunar Soil, the platform's loyalty points, measured in grams (克)."
        }
      },
      "required": ["uid", "email", "kycStatus", "createdAt"]
    },
    "UserAddress": {
      "title": "User Address",
      "description": "Represents a user's shipping address.",
      "type": "object",
      "properties": {
        "recipientName": {
          "type": "string",
          "description": "The name of the recipient."
        },
        "phone": {
          "type": "string",
          "description": "The recipient's phone number."
        },
        "country": {
          "type": "string",
          "description": "Country of the address."
        },
        "province": {
          "type": "string",
          "description": "Province or state of the address."
        },
        "city": {
          "type": "string",
          "description": "City of the address."
        },
        "addressLine1": {
          "type": "string",
          "description": "The primary line of the address."
        },
        "addressLine2": {
          "type": "string",
          "description": "The secondary line of the address (optional)."
        },
        "postalCode": {
          "type": "string",
          "description": "The postal code."
        },
        "isDefault": {
          "type": "boolean",
          "description": "Whether this is the default shipping address."
        }
      },
      "required": [
        "recipientName",
        "phone",
        "country",
        "province",
        "city",
        "addressLine1",
        "postalCode"
      ]
    },
    "Promo": {
      "title": "Promotion",
      "description": "Represents a promotional event or page, like Cyber Monday.",
      "type": "object",
      "properties": {
        "heroTitle": {
          "type": "string",
          "description": "The main headline of the promo page."
        },
        "heroDescription": {
          "type": "string",
          "description": "The descriptive text under the main headline."
        },
        "heroBackgroundGif": {
          "type": "string",
          "format": "uri",
          "description": "URL for the animated GIF in the hero section background."
        },
        "primaryButtonText": {
          "type": "string",
          "description": "Text for the main call-to-action button."
        },
        "secondaryButtonText": {
          "type": "string",
          "description": "Text for the secondary action button."
        },
        "productsSectionTitle": {
          "type": "string",
          "description": "The title for the featured products section."
        },
        "featuredProductIds": {
          "type": "array",
          "description": "A list of product IDs to feature in this promotion.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "heroTitle",
        "heroDescription",
        "heroBackgroundGif",
        "primaryButtonText",
        "secondaryButtonText",
        "productsSectionTitle"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a transaction between a buyer and a seller.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "price": { "type": "number", "description": "The original price of the product." },
        "shippingFee": { "type": "number", "description": "The calculated shipping fee." },
        "totalAmount": { "type": "number", "description": "The total amount (price + shippingFee)." },
        "currency": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["Pending", "In Escrow", "Shipped", "Awaiting Confirmation", "Completed", "Disputed", "Cancelled"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "buyerReviewId": { "type": "string" },
        "sellerReviewId": { "type": "string" },
        "shippingAddress": {
          "type": "object",
          "description": "A snapshot of the selected shipping address at the time of order.",
          "properties": {
            "recipientName": { "type": "string" },
            "phone": { "type": "string" },
            "country": { "type": "string" },
            "province": { "type": "string" },
            "city": { "type": "string" },
            "addressLine1": { "type": "string" },
            "addressLine2": { "type": "string" },
            "postalCode": { "type": "string" }
          },
           "required": ["recipientName", "phone", "country", "province", "city", "addressLine1", "postalCode"]
        },
        "shippingMethod": { "type": "string", "enum": ["Seller Pays", "Buyer Pays", "In-person"] }
      },
      "required": ["productId", "buyerId", "sellerId", "price", "shippingFee", "totalAmount", "currency", "status", "createdAt", "shippingAddress", "shippingMethod"]
    },
    "Review": {
      "title": "Transaction Review",
      "description": "A review submitted by a user for a transaction.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "revieweeId": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller"] },
        "rating": { "type": "string", "enum": ["Good", "Neutral", "Bad"] },
        "comment": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "reviewerId", "revieweeId", "role", "rating", "createdAt"]
    },
    "LunarSoilLedgerEntry": {
        "title": "Lunar Soil Ledger Entry",
        "description": "Represents a single transaction of Lunar Soil, used to track expiration.",
        "type": "object",
        "properties": {
            "amount": { "type": "number" },
            "earnedAt": { "type": "string", "format": "date-time" },
            "expiresAt": { "type": "string", "format": "date-time" },
            "source": { "type": "string", "description": "e.g., 'review', 'daily-login', 'purchase'" }
        },
        "required": ["amount", "earnedAt", "expiresAt", "source"]
    }
  },
  "auth": {
    "providers": ["google.com", "facebook.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores public user profile data."
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/UserAddress" },
      "description": "Stores a user's shipping addresses."
    },
    "/promos/{promoId}": {
      "schema": { "$ref": "#/entities/Promo" },
      "description": "Stores data for promotional pages."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores transaction data between users."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores reviews for transactions."
    },
    "/users/{userId}/lunarSoilLedger/{ledgerEntryId}": {
      "schema": { "$ref": "#/entities/LunarSoilLedgerEntry" },
      "description": "Ledger for a user's Lunar Soil transactions to handle expiration."
    }
  }
}
