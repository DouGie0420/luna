rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 輔助函數 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // 修復版 getRole：增加對未登入狀態的保護，防止報錯
    function getRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'guest';
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      // 只有在登入狀態下才去校驗管理組權限
      return isSignedIn() && hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 1. 配置與全局資訊 ---
    match /configs/{configId} {
      allow get, list: if true; 
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /settings/{settingsId} {
      allow get, list: if true;
      allow write: if hasRole(['admin', 'ghost']);
    }
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /promos/{promoId} {
        allow get, list: if true;
        allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // ✅ 修復：認證商戶集合 (merchants)
    match /merchants/{merchantId} {
      allow get: if true;
      // 增加 "limit" 存在性校驗，防崩潰
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 
      allow write: if isAdminGroup();
    }

    // --- 2. 用戶集合 (users) ---
    match /users/{userId} {
      allow get: if true;
      
      // ✅ 終極修復：確保 request.query.limit 存在時才校驗，避免無 limit 查詢時引發錯誤導致崩潰
      // 嚴格鎖死最大抓取上限為 50 個文檔
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if hasRole(['admin', 'ghost']);
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        (request.auth.uid != userId && (
          (hasRole(['admin', 'ghost'])) ||
          (hasRole(['staff', 'support']) && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        )) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'followersCount', 'following', 'followingCount']))
      );

      match /notifications/{notificationId} { 
        allow read, list, update, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn();
      }
      match /addresses/{addressId} { allow read, list, create, update, delete: if isSignedIn() && request.auth.uid == userId; }
      match /lunarSoilLedger/{ledgerEntryId} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
    }

    // --- 3. 內容集合 (products, bbs) ---
    match /products/{productId} {
      // 確保商品對所有人可見
      allow read, list: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.sellerId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'views'])) ||
        (request.resource.data.status == 'under_review' && resource.data.status == 'active')
      );
      match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'replies', 'views']))
      );

      match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    // --- 4. 交易與訂單 (orders) ---
    match /orders/{orderId} {
      // 增加 limit 存在校驗
      allow list: if isAdminGroup() || (isSignedIn() && ("limit" in request.query && request.query.limit <= 50));
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      allow delete: if hasRole(['admin', 'ghost']);
    }

    match /reviews/{reviewId} {
      allow get: if true;
      allow write: if isSignedIn() && (request.resource.data.reviewerId == request.auth.uid || isAdminGroup());
      allow list: if ("limit" in request.query && request.query.limit <= 50);
    }

    // --- 5. 聊天與支持 ---
    match /direct_chats/{chatId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    match /support_tickets/{ticketId} {
      allow list: if isAdminGroup();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));

      match /messages/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // --- 6. 後台管理模組 ---
    match /paymentChangeRequests/{reqId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdminGroup();
        allow list: if isAdminGroup();
    }
    match /proApplications/{applicationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminGroup());
      allow list, update: if isAdminGroup();
      allow delete: if hasRole(['admin', 'ghost']);
    }

    // --- 7. 🏠 房屋租賃模組 (rentalProperties) ---
    match /rentalProperties/{propertyId} {
      // 所有人可以查看狀態為 active 的房源，房主和管理員可以查看自己所有狀態的房源
      allow read: if resource.data.status == 'active' || (isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdminGroup()));
      
      // ✅ 終極修復：只有 PRO 認證商戶或管理員可以創建房源。使用 .get('isPro', false) 避免字段缺失報錯
      allow create: if isSignedIn() && 
                      request.resource.data.ownerId == request.auth.uid &&
                      (isAdminGroup() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isPro', false) == true);
      
      // 只有房主或管理員可以修改/刪除
      allow update, delete: if isSignedIn() && 
                              (request.auth.uid == resource.data.ownerId || isAdminGroup());
    }

    // --- 默認拒絕 ---
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}