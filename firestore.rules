
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Public profile data is readable by anyone
      allow get: if true;
      // Users can only write to their own profile
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /notifications/{notiId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn(); // Allow writing for functions/admins
      }
      
      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /bbs/{docId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }

    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    match /orders/{orderId} {
       // Allow a user to get their own order, either as a buyer or seller.
       allow get: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);

       // Allow a user to create an order for themselves.
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
       
       // Allow buyer or seller to update an order.
       allow update: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
       
       // This rule allows a user to LIST orders only if they are querying by their own buyerId.
       allow list: if isSignedIn() && request.query.buyerId == request.auth.uid;
    }

    // Contextual comment rules
    match /products/{productId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /bbs/{postId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    match /reviews/{reviewId} {
       allow get, list: if true;
       allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
    }

    match /paymentChangeRequests/{requestId} {
      // A user can create a request for themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // A user can read their own request, and admins can read any.
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role IN ['admin', 'staff', 'ghost']);

      // A user can list their own requests, and admins can list all.
      allow list: if isSignedIn() && (request.query.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role IN ['admin', 'staff', 'ghost']);

      // Admins/staff can update any request
      allow update: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role IN ['admin', 'staff', 'ghost'];
    }
  }
}

    