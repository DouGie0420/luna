
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function getUserRole(userId) {
      // Use the target userId, not necessarily the requesting user's id
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(userId)) ? getUserData(userId).role : 'guest';
    }

    function isRequestingUserAdmin() {
      return getUserRole(request.auth.uid) == 'admin';
    }
    
    function isRequestingUserGhost() {
        return getUserRole(request.auth.uid) == 'ghost';
    }

    function isRequestingUserStaff() {
        return getUserRole(request.auth.uid) in ['staff', 'ghost', 'admin', 'support'];
    }

    function isRequestingUserSupport() {
        return getUserRole(request.auth.uid) in ['support', 'staff', 'ghost', 'admin'];
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);

      // Allow user to link their Web3 wallet for the first time.
      allow update: if isOwner(userId) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletAddress', 'isWeb3Verified']) &&
                      resource.data.walletAddress == null &&
                      request.resource.data.isWeb3Verified == true;

      // General-purpose profile update by the owner.
      allow update: if isOwner(userId) &&
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                         'uid', 'createdAt', 'creditScore', 'creditLevel', 'lunarSoil',
                         'rating', 'reviewsCount', 'salesCount', 'purchasesCount', 'role',
                         'followersCount', 'followingCount', 'postsCount', 'featuredCount',
                         'isPro', 'isWeb3Verified', 'isNftVerified', 'walletAddress'
                       ]);
      
      // Allow user to change their role from 'guest' to 'user' upon first verified login.
      allow update: if isOwner(userId) &&
                       resource.data.role == 'guest' &&
                       request.resource.data.role == 'user' &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['role', 'emailVerified', 'lastLogin', 'displayName', 'photoURL']);

      // Allow user to increment/decrement their own following count.
      allow update: if isOwner(userId) &&
                       (request.resource.data.followingCount == resource.data.followingCount + 1 ||
                        request.resource.data.followingCount == resource.data.followingCount - 1) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followingCount']);
      
      // Allow any signed-in user to increment/decrement another user's followers count.
      allow update: if isSignedIn() &&
                       (request.resource.data.followersCount == resource.data.followersCount + 1 ||
                        request.resource.data.followersCount == resource.data.followersCount - 1) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']);
      
      // Allow user to increment their own post count (e.g., when creating a new post).
      allow update: if isOwner(userId) &&
                       request.resource.data.postsCount == resource.data.postsCount + 1 &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postsCount']);

      // Allow staff/admins to manage user profiles, with safeguards.
      allow update: if isRequestingUserStaff() &&
                      // Prevent editing immutable fields
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt']) &&
                      // Prevent staff/ghosts from editing admins/ghosts. Admins can edit anyone.
                      (isRequestingUserAdmin() || !(getUserRole(userId) in ['admin', 'ghost']));

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isRequestingUserStaff();
      }
      
      match /notifications/{notificationId} {
          allow read, update: if isOwner(userId);
          allow create: if isSignedIn(); 
      }
      
      match /lunarSoilLedger/{ledgerId} {
        allow write: if isRequestingUserStaff();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid && request.resource.data.location != null;
      
      // Rule 1: Staff can ONLY modify the status (for flagging/admin panel management).
      allow update: if isRequestingUserStaff() &&
        request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
        request.resource.data.diff(resource.data).affectedKeys().has('status');

      // Rule 2: Product owner can edit their product, but not protected fields.
      allow update: if resource.data.sellerId == request.auth.uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'location', 'likes', 'favorites', 'views', 'searchHits', 'likedBy', 'favoritedBy', 'sellerId', 'createdAt']);
         
      // Rule 3: Any signed-in user can update interaction counts.
      allow update: if isSignedIn() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'favoritedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits'])
        );
      
      // Admin can delete for real from the admin panel.
      allow delete: if isRequestingUserAdmin();
    }
    
    // PROMOS (Managed by Staff/Admins/Ghosts)
    match /promos/{promoId} {
      allow read, list: if true;
      allow write: if isRequestingUserStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isRequestingUserAdmin() || isRequestingUserGhost();
       allow list: if isRequestingUserAdmin() || isRequestingUserGhost();
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       allow read, list: if true;
       allow create: if isOwner(request.resource.data.reviewerId);
       allow update, delete: if isOwner(resource.data.reviewerId) || isRequestingUserAdmin() || isRequestingUserGhost();
    }

    // SUPPORT TICKETS (Managed by Support/Admins/Ghosts)
    match /supportTickets/{ticketId} {
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isRequestingUserSupport();
        allow list: if isRequestingUserSupport();
        allow create: if isSignedIn();
    }

    // BBS Posts
    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn() 
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.author.id == request.auth.uid
                    && request.resource.data.location != null;
      
      // Rule 1: Staff can ONLY modify the status or featured flag.
      allow update: if isRequestingUserStaff() && (
            (request.resource.data.diff(resource.data).affectedKeys().size() == 1 && request.resource.data.diff(resource.data).affectedKeys().has('status')) ||
            (request.resource.data.diff(resource.data).affectedKeys().size() == 1 && request.resource.data.diff(resource.data).affectedKeys().has('isFeatured'))
         );

      // Rule 2: Post owner can edit their post, but not protected fields.
      allow update: if isOwner(resource.data.authorId) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'location', 'likes', 'favorites', 'likedBy', 'favoritedBy', 'replies', 'views', 'searchHits', 'isFeatured', 'authorId', 'createdAt']);

      // Rule 3: Any signed-in user can update interaction counts and replies.
      allow update: if isSignedIn() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'favoritedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits']) ||
          ((request.resource.data.replies == resource.data.replies + 1 || request.resource.data.replies == resource.data.replies - 1) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']))
        );

      allow delete: if isRequestingUserAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'likedBy', 'dislikedBy']);
        allow delete: if isOwner(resource.data.authorId) || isRequestingUserAdmin();
      }
    }
  }
}
