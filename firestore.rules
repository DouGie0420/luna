rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- жқ“ж–ҝе§ӘйҚ‘иҠҘжҡ© ---
    function isSignedIn() {
      return request.auth != null;
    }

    // ж·ҮоҶјдә¬йҗ—?getRoleй”ӣж°¬о–ғйҚ”зҠІзҡӘйҸҲоҒҶж«ҘйҚҸгғ§еӘӯйҺұе¬¬ж®‘ж·ҮжҝҠо„°й”ӣеІ„ж§»е§қгҲ зүЁй–·?
    function getRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'guest';
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      // йҚҷоҒ…ж№ҒйҚҰг„§ж«ҘйҚҸгғ§еӘӯйҺұе¬©з¬…йҺөе¶…е№“йҸҚпҝ оҹҙз» пј„жӮҠз»ІеӢ¬з‘ й—„?(admin/ghost/staff/support)
      return isSignedIn() && hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    function walletBindingFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'walletAddress',
        'walletBindTime',
        'isWeb3Verified'
      ]);
    }

    function isFirstWalletBindingUpdate(userId) {
      return request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'walletAddress',
          'walletBindTime',
          'isWeb3Verified'
        ]) &&
        (
          !('walletAddress' in resource.data) ||
          resource.data.walletAddress == null ||
          resource.data.walletAddress == ''
        ) &&
        request.resource.data.walletAddress is string &&
        request.resource.data.walletAddress.size() >= 10 &&
        request.resource.data.isWeb3Verified == true;
    }

    function isAdminWalletBindingUpdate(userId) {
      return request.auth.uid != userId &&
        isAdminGroup() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'walletAddress',
          'walletBindTime',
          'isWeb3Verified'
        ]);
    }
    // --- 1. й–°е¶Үз–Ҷй‘ёеӣ§еҸҸзҒһвӮ¬з’©еӣӘв–• ---
    match /configs/{configId} {
      allow read: if true; 
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost']); // йҚӨеӯҳзүёй—„ж„¬еҹ—й”ӣжӯҙtaffйҚңе®»upportйҗ’в„ғз‘ ж·ҮоҶҪж•јз»ҜиҚӨеҪ“з‘·о… з–Ҷ
    }
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /promos/{promoId} {
        allow read: if true;
        allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- йҚҹе—ҳеҹ—й—Ҷе——жӮҺ (merchants) ---
    match /merchants/{merchantId} {
      allow get: if true;
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 
      allow write: if isAdminGroup();
    }

    // --- 2. йҗўг„Ұеҹ—й—Ҷе——жӮҺ (users) ---
    match /users/{userId} {
      allow get: if true;
      
      // йҚӨеӯҳзүёй–№ж Ёо„ҙйҸҲвӮ¬жҫ¶С„е§„йҚҷж Ұз¬Ӯй—„ж„®еҒӨ 50 йҚҠе¬«жһғеҰҫ?
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if hasRole(['admin', 'ghost']);
      
      // йүҒ?еЁҶе©ҮжӘәж·ҮоҶјдә¬й”ӣж°¬жҜҡйҸҚеҘёжӘәйҚ’?staff йҚң?support ж¶“е¶Ҳе…ҳж·ҮоҶҪж•јйҗўг„Ұеҹ—з’©еӣЁжһЎ (й—„гӮ„з°Ўйҗ—з‘°з•ҫйҗЁеӢ«еҸ•й—Ғе¬ӯв–“йҸҒзЁҝж«’)
      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
          !walletBindingFieldsChanged()
        ) ||
        isFirstWalletBindingUpdate(userId) ||
        (request.auth.uid != userId && hasRole(['admin', 'ghost'])) || 
        isAdminWalletBindingUpdate(userId) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'followersCount', 'following', 'followingCount']))
      );

      match /notifications/{notificationId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /addresses/{addressId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId; 
      }
      match /lunarSoilLedger/{ledgerEntryId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId; 
      }
    }

    // --- 3. йҚҸСғоҶҗй—Ҷе——жӮҺ (products, bbs) ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.sellerId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'views'])) ||
        (request.resource.data.status == 'under_review' && resource.data.status == 'active') ||
        // вң… е…Ғи®ёд№°е®¶еңЁз»“иҙҰж—¶жӣҙж–°е•Ҷе“ҒзҠ¶жҖҒпјҲatomic reservationпјүпјҡactiveвҶ”reservedвҶ”sold
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.auth.uid != resource.data.sellerId &&
          resource.data.status in ['active', 'reserved'] &&
          request.resource.data.status in ['reserved', 'active', 'sold']
        )
      );
      match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    match /bbs/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'replies', 'views']))
      );

      match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    // --- 4. жөңгӮҶж§—й‘ёеӣӘв–ҠйҚ ?(orders) ---
    match /orders/{orderId} {
      allow list: if isAdminGroup() || (isSignedIn() && ("limit" in request.query && request.query.limit <= 50));
      allow get: if isSignedIn() && (
        resource == null || // вңЁ дҝ®еҫ©пјҡе…ҒиЁұеүҚз«ҜзӣЈиҒҪйӮ„жңӘеүөе»әе®ҢжҲҗзҡ„иЁӮе–®ж–ҮжӘ”
        request.auth.uid == resource.data.buyerId ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid in resource.data.get('participants', []) || // вңЁ дҝ®еҫ©пјҡдҪҝз”Ё get()
        isAdminGroup()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.buyerId ||
        request.auth.uid == resource.data.sellerId ||
        request.auth.uid in resource.data.get('participants', []) ||
        isAdminGroup()
      );
      // йүҒ?ж·ҮоҶјдә¬й”ӣжӯҙtaff йҚң?support йҺҝдҪ№ж№Ғз‘·еӮҡжҹҲз» пј„жӮҠйҗЁеӢ«еҸҸй–®г„Ұз‘ й—„ж„¶зҙқйҚҸдҪҪЕ«йҚ’оҒҲж«Һ
      allow delete: if isAdminGroup(); 
    }

    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if ("limit" in request.query && request.query.limit <= 50);
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.reviewerId == request.auth.uid ||
        isAdminGroup()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.reviewerId == request.auth.uid ||
        isAdminGroup()
      );
    }

    // --- bookings йӣҶеҗҲ ---
    match /bookings/{bookingId} {
      allow list: if isAdminGroup() || (isSignedIn() && ("limit" in request.query && request.query.limit <= 200));
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId ||
        request.auth.uid == resource.data.hostId ||
        request.auth.uid == resource.data.ownerId ||
        isAdminGroup()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId ||
        request.auth.uid == resource.data.hostId ||
        request.auth.uid == resource.data.ownerId ||
        isAdminGroup()
      );
      allow delete: if isAdminGroup();
    }

    // --- 5. й‘ұе©ӮгҒүй‘ёеӣЁж•®йҺё?---
    
    // йүҒ?йҸӮжқҝо–ғй”ӣж°¬зҡҘй—ҒвӮ¬йҗҗ?ChatWindow з»ІеӢӘж¬ўй–°е¶Үз–ҶйҗЁеӢ®в–ҠйҚ оҶҝдә°жҫ¶в•…жіҰйҚҡ?
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        isAdminGroup() ||
        resource == null || // вңЁ дҝ®еҫ©пјҡеҲӨж–·ж–ҮжӘ”дёҚеӯҳеңЁ
        request.auth.uid in resource.data.get('participants', []) // вңЁ дҝ®еҫ©
      );
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && (
        isAdminGroup() ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAdminGroup();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isAdminGroup() ||
          !exists(/databases/$(database)/documents/chats/$(chatId)) ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', []) // вңЁ дҝ®еҫ©
        );
        allow create: if isSignedIn() && (
          isAdminGroup() ||
          (request.auth.uid == request.resource.data.senderId && (
            !exists(/databases/$(database)/documents/chats/$(chatId)) ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', []) // вңЁ дҝ®еҫ©
          ))
        );
        allow update, delete: if isAdminGroup();
      }
    }

    match /direct_chats/{chatId} {
      allow read: if isSignedIn() && (
        resource == null || // вңЁ дҝ®еҫ©
        request.auth.uid in resource.data.get('participants', [])
      );
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        // жөЈи·Ёж•Ө get зә°иҪ°з№ҡйҚ—е……з©¶йҚҷоҒҮз•қйҚҷж Ұз«ҙе§ҠжҝҠв–•йҺӯоҲӨзҙқж¶”зҶ»е…ҳйҸҚпҝ оҹҙйҗ–еүҒзӨҶзҒҸе¶Ҳв”ҚйҗЁ?participants
        allow read: if isSignedIn() && (
          !exists(/databases/$(database)/documents/direct_chats/$(chatId)) || // вңЁ дҝ®еҫ©
          request.auth.uid in get(/databases/$(database)/documents/direct_chats/$(chatId)).data.get('participants', [])
        );
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    match /support_tickets/{ticketId} {
      allow list: if isAdminGroup();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn() && (
        resource == null || // вңЁ дҝ®еҫ©
        resource.data.userId == request.auth.uid || 
        isAdminGroup()
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          !exists(/databases/$(database)/documents/support_tickets/$(ticketId)) || // вңЁ дҝ®еҫ©
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || 
          isAdminGroup()
        );
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // --- 6. йҖҡзҹҘйӣҶеҗҲ (notifications/{userId}/items) ---
    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 7. FCM жө гӮҮеўқз» пј„жӮҠ ---
    match /fcm_tokens/{userId} {
      // йҗўг„Ұеҹ—йҚҷоҒҮе…ҳз’ҒвӮ¬зҖөоӮҘеҡңе®ёиҫ©ж®‘FCMжө гӮҮеўқ
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // з» пј„жӮҠйҚқвҖіеҪІжө гғЁз•қйҚҷж ЁеўҚйҸҲеЎ…CMжө гӮҮеўқ
      allow read: if isAdminGroup();
    }

    // --- 7. USDT жөңгӮҶж§—з‘·ж©ҖеҜ— ---
    match /usdt_transactions/{txId} {
      // йҗўг„Ұеҹ—йҚҷоҲҷдә’йҚ“йқӣзј“й‘·оҒ„з№ҒйҗЁеӢӘж°ҰйҸ„ж’№оһҫй–·?
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // йҗўг„Ұеҹ—йҚҷоҲҷдә’з’ҒвӮ¬йҚҷж ¬еҡңе®ёиҫ©ж®‘жөңгӮҶж§—з‘·ж©ҖеҜ—
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // з» пј„жӮҠйҚқвҖіеҪІжө гғЁз•қйҚҷж ЁеўҚйҸҲеӨүж°ҰйҸ„ж’№оһҫй–·?
      allow read: if isAdminGroup();
      // жөңгӮҶж§—з‘·ж©ҖеҜ—ж¶“вӮ¬йҸғп№ҖеЈҚеҜӨиҪ°з¬үйҚҷоҲҷж…ЁйҸҖзҷёзҙҷй—ғеҸүо„ӣз»Ўв„ғж•јй”ӣ?
      allow update, delete: if false;
    }

    // --- 8. еҜ°еұҪеҪҙз» пј„жӮҠеҰҜпј„зҘ« ---
    match /walletChangeRequests/{requestId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.oldWalletAddress is string &&
        request.resource.data.newWalletAddress is string &&
        request.resource.data.newWalletAddress.size() >= 10 &&
        request.resource.data.source in ['auto_switch', 'manual'];

      allow get, list: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdminGroup());

      allow update: if isAdminGroup() &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.oldWalletAddress == resource.data.oldWalletAddress &&
        request.resource.data.newWalletAddress == resource.data.newWalletAddress;

      allow delete: if hasRole(['admin', 'ghost']);
    }
    match /paymentChangeRequests/{reqId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdminGroup();
    }
    match /proApplications/{applicationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminGroup());
      allow list, update: if isAdminGroup();
      // йүҒ?ж·ҮоҶјдә¬й”ӣжӯҙtaff йҚң?support йҺҝдҪ№ж№Ғ KYC йҗўе® зҸӣйҗЁеӢ«еҸҸй–®г„Ұз‘ й—„ж„¶зҙқйҚҸдҪҪЕ«йҚ’оҒҲж«Һ
      allow delete: if isAdminGroup();
    }

    // --- 8. йҰғеҪ” йҺҙеһ®зңҝз»үзҶ»зЎҹеҰҜпј„зҘ« (rentalProperties) ---
    match /rentalProperties/{propertyId} {
      allow read: if resource.data.status == 'active' || (isSignedIn() && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.hostId ||
        isAdminGroup()
      ));
      allow create: if isSignedIn() &&
                      (request.resource.data.ownerId == request.auth.uid || request.resource.data.hostId == request.auth.uid) &&
                      (isAdminGroup() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isPro', false) == true);
      allow update, delete: if isSignedIn() &&
                              (request.auth.uid == resource.data.ownerId || request.auth.uid == resource.data.hostId || isAdminGroup());
    }

    // --- 9. рҹҢҷ жңҲеЈӨAIеҫ®е®Үе®ҷ (Universe) ---

    // AIеұ…ж°‘жіЁеҶҢдҝЎжҒҜ вҖ” д»»дҪ•дәәеҸҜиҜ»пјҢAPIи·Ҝз”ұйҖҡиҝҮжңҚеҠЎз«ҜеҶҷе…Ҙ
    match /universe_ai_entities/{wallet} {
      allow read: if true;
      allow create: if true;  // APIи·Ҝз”ұеӨ„зҗҶйӘҢиҜҒйҖ»иҫ‘
      allow update: if true;  // APIи·Ҝз”ұеӨ„зҗҶи®ӨиҜҒ
      allow delete: if isAdminGroup();
    }

    // DJжҺ’иЎҢжҰң вҖ” д»»дҪ•дәәеҸҜиҜ»пјҢжңҚеҠЎз«ҜеҶҷе…Ҙ
    match /universe_dj_rankings/{wallet} {
      allow read: if true;
      allow write: if isSignedIn() || true;  // APIи·Ҝз”ұе’Ңзҷ»еҪ•з”ЁжҲ·еқҮеҸҜ
    }

    // DJж—¶й—ҙж§Ҫ вҖ” д»»дҪ•дәәеҸҜиҜ»пјҢзҷ»еҪ•з”ЁжҲ·еҸҜйў„зәҰ
    match /universe_dj_slots/{slotId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdminGroup();
    }

    // е®Ўж ёиҝқи§„и®°еҪ• вҖ” з®ЎзҗҶе‘ҳеҸҜиҜ»е…ЁйғЁпјҢAIеҸҜиҜ»иҮӘе·ұзҡ„
    match /universe_moderation_violations/{violationId} {
      allow read: if isSignedIn() && (
        resource.data.walletAddress == request.auth.uid ||
        isAdminGroup()
      );
      allow create: if true;  // APIи·Ҝз”ұеӨ„зҗҶ
      allow update, delete: if isAdminGroup();
    }

    // еӨ„зҪҡи®°еҪ• вҖ” з®ЎзҗҶе‘ҳеҸҜиҜ»е…ЁйғЁпјҢAIеҸҜиҜ»иҮӘе·ұзҡ„
    match /universe_penalty_records/{recordId} {
      allow read: if isSignedIn() && (
        resource.data.walletAddress == request.auth.uid ||
        isAdminGroup()
      );
      allow create: if true;  // APIи·Ҝз”ұеӨ„зҗҶ
      allow update, delete: if isAdminGroup();
    }

    // жңҲеЈӨдәӨжҳ“и®°еҪ• вҖ” з”ЁжҲ·еҸҜиҜ»иҮӘе·ұзҡ„пјҢз®ЎзҗҶе‘ҳеҸҜиҜ»е…ЁйғЁ
    match /universe_lunar_transactions/{txId} {
      allow read: if true;
      allow create: if true;  // APIи·Ҝз”ұеӨ„зҗҶ
      allow update, delete: if false;  // дәӨжҳ“и®°еҪ•дёҚеҸҜдҝ®ж”№
    }

    // --- й»ҳи®ӨжӢ’з»қ ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}