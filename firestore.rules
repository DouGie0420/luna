rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions to check user roles.
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role == 'staff' || isAdmin());
    }

    function isSupport() {
        return isSignedIn() && (getUserData().role == 'support' || isAdmin());
    }

    // USER PROFILES & SUBCOLLECTIONS
    match /users/{userId} {
      // Anyone can read a user's profile.
      allow read: if true;
      // Only the user themselves or an admin can update their profile.
      allow write: if isOwner(userId) || isAdmin();

      // User subcollections are private to the user or admins.
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{notificationId} {
        // Users can only access their own notifications.
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can view products.
      allow read: if true;
      // Any signed-in user can create a product, but must set themselves as the seller.
      allow create: if isSignedIn() && request.resource.data.seller.id == request.auth.uid;
      // Only the original seller or a staff/admin can update/delete a product.
      allow update, delete: if (resource.data.seller.id == request.auth.uid) || isStaff();
    }
    
    // PROMOS (Managed by Staff/Admins)
    match /promos/{promoId} {
      // Anyone can view promotional content.
      allow read: if true;
      // Only staff and admins can create or modify promos.
      allow write: if isStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       // Only the buyer, seller, or an admin can access an order.
       allow read, write: if isOwner(resource.data.buyerId) 
                         || isOwner(resource.data.sellerId) 
                         || isAdmin();
       // Only a signed-in user can create an order, and they must be the buyer.
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       // Only the reviewer, the reviewee, or an admin can access a review.
       allow read, write: if isOwner(resource.data.reviewerId)
                         || isOwner(resource.data.revieweeId)
                         || isAdmin();
       // Only the reviewer can create a review.
       allow create: if isOwner(request.resource.data.reviewerId);
    }

    // SUPPORT TICKETS (Managed by Support/Admins)
    match /supportTickets/{ticketId} {
        // Allow the user who created the ticket, support staff, and admins to access.
        allow read, update: if isOwner(resource.data.userId) || isSupport();
        // Allow any signed-in user to create a ticket.
        allow create: if isSignedIn();
        // Only support staff and admins can delete tickets.
        allow delete: if isSupport();
    }
  }
}
