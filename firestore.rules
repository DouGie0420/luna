
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function getUserRole(userId) {
      // Use the target userId, not necessarily the requesting user's id
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(userId)) ? getUserData(userId).role : 'guest';
    }

    function isRequestingUserAdmin() {
      return getUserRole(request.auth.uid) == 'admin';
    }
    
    function isRequestingUserGhost() {
        return getUserRole(request.auth.uid) == 'ghost';
    }

    function isRequestingUserStaff() {
        return getUserRole(request.auth.uid) in ['staff', 'ghost', 'admin'];
    }

    function isRequestingUserSupport() {
        return getUserRole(request.auth.uid) in ['support', 'staff', 'ghost', 'admin'];
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // PRODUCTS
    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid && request.resource.data.location != null;
      
      allow update: if ( (resource.data.sellerId == request.auth.uid) || isRequestingUserStaff() ) 
                      && request.resource.data.location == resource.data.location;

      allow update: if isSignedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'searchHits']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits'])
      );
      
      allow delete: if (resource.data.sellerId == request.auth.uid) || isRequestingUserStaff();
    }
    
    // PROMOS (Managed by Staff/Admins/Ghosts)
    match /promos/{promoId} {
      allow read, list: if true;
      allow write: if isRequestingUserStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isRequestingUserAdmin() || isRequestingUserGhost();
       allow list: if isRequestingUserAdmin() || isRequestingUserGhost();
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       allow read, list: if true;
       allow create: if isOwner(request.resource.data.reviewerId);
       allow update, delete: if isOwner(resource.data.reviewerId) || isRequestingUserAdmin() || isRequestingUserGhost();
    }

    // SUPPORT TICKETS (Managed by Support/Admins/Ghosts)
    match /supportTickets/{ticketId} {
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isRequestingUserSupport();
        allow list: if isRequestingUserSupport();
        allow create: if isSignedIn();
    }

    // BBS Posts
    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn() 
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.author.id == request.auth.uid
                    && request.resource.data.location != null;
      
      allow update: if (isOwner(resource.data.authorId) 
                        && request.resource.data.location == resource.data.location
                        && request.resource.data.likes == resource.data.likes
                        && request.resource.data.favorites == resource.data.favorites
                        && request.resource.data.replies == resource.data.replies
                      ) 
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'favorites', 'likedBy', 'favoritedBy', 'views', 'searchHits']));
      
      allow delete: if resource.data.authorId == request.auth.uid || isRequestingUserAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'dislikes', 'likedBy', 'dislikedBy']);
        allow delete: if resource.data.authorId == request.auth.uid || isRequestingUserAdmin();
      }
    }
  }
}
