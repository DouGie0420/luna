rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Allow access if the user has an 'admin' role in their user document.
      // Use exists() for safety to prevent errors on non-existent documents.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS
    match /users/{userId} {
      // User profiles are public, but only the owner or an admin can write.
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();

      // Subcollections for users
      match /addresses/{addressId} {
        // Only owner or admin can access addresses.
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         // Only owner or admin can access the ledger.
         allow read, write: if request.auth.uid == userId || isAdmin();
      }
      match /notifications/{notificationId} {
        // Only owner or admin can access notifications.
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can read products.
      allow read: if true;
      // Users can create products if the seller ID matches their UID.
      allow create: if request.auth.uid == request.resource.data.seller.id;
      // Users can only update/delete their own products, or an admin can.
      allow update, delete: if resource.data.seller.id == request.auth.uid || isAdmin();
    }
    
    // PROMOS
    match /promos/{promoId} {
      // Anyone can read promotional content.
      allow read: if true;
      // Only admins can write to promos.
      allow write: if isAdmin();
    }

    // ORDERS & REVIEWS
    match /orders/{orderId} {
       // Involved parties (buyer, seller) or admin can read/write.
       allow read, write: if request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId 
                         || isAdmin();
       // Only the buyer can create an order.
       allow create: if request.auth.uid == request.resource.data.buyerId;
    }
    match /reviews/{reviewId} {
       // Involved parties or admin can access.
       allow read, write: if request.auth.uid == resource.data.reviewerId
                         || request.auth.uid == resource.data.revieweeId
                         || isAdmin();
       // Only the reviewer can create a review.
       allow create: if request.auth.uid == request.resource.data.reviewerId;
    }
  }
}
