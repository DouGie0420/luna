
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 辅助函数 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'guest';
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      return hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 1. 播放器与全局配置 ---
    match /configs/{configId} {
      allow get, list: if true; 
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /settings/{settingsId} {
      allow get, list: if true;
      allow write: if hasRole(['admin', 'ghost']);
    }
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /promos/{promoId} {
        allow get, list: if true;
        allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- 2. 用户集合 (users) ---
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdminGroup() || request.query.limit <= 50;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if hasRole(['admin', 'ghost']);
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        (request.auth.uid != userId && (
          (hasRole(['admin', 'ghost'])) ||
          (hasRole(['staff', 'support']) && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        )) ||
        (request.auth.uid != userId && request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'followersCount', 'following', 'followingCount']))
      );

      match /notifications/{notificationId} { 
        allow read, list, update, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn();
      }
      match /addresses/{addressId} { allow read, list, create, update, delete: if isSignedIn() && request.auth.uid == userId; }
      match /lunarSoilLedger/{ledgerEntryId} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
    }

    // --- 3. 内容集合 (products, bbs) ---
    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      allow update: if isSignedIn() && (
        (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'views'])) ||
        (request.resource.data.status == 'under_review' && resource.data.status == 'active' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );
       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      }
    }
    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'replies', 'views']))
      );
       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      }
    }

    // --- 4. 交易与租赁 (orders, rentalProperties, reviews) ---
    match /orders/{orderId} {
      allow list: if isAdminGroup() || (isSignedIn() && request.query.limit <= 50);
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      allow delete: if isAdminGroup();
    }
    match /rentalProperties/{propertyId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdminGroup());
      match /bookings/{bookingId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update: if isSignedIn() && (
            request.auth.uid == resource.data.userId || 
            get(/databases/$(database)/documents/rentalProperties/$(propertyId)).data.ownerId == request.auth.uid ||
            isAdminGroup()
        );
        allow delete: if isAdminGroup();
      }
    }
     match /reviews/{reviewId} {
      allow get: if true;
      allow write: if isSignedIn() && (request.resource.data.reviewerId == request.auth.uid || isAdminGroup());
      allow list: if isSignedIn() && request.query.limit <= 50;
    }


    // --- 5. 聊天系统 (direct_chats, support_tickets) ---
    match /direct_chats/{chatId} {
      allow get, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && get(/databases/$(database)/documents/direct_chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId && (
            request.auth.uid in get(/databases/$(database)/documents/direct_chats/$(chatId)).data.participants &&
            (
                get(/databases/$(database)/documents/direct_chats/$(chatId)).data.isFriendMode == true ||
                get(/databases/$(database)/documents/direct_chats/$(chatId)).data.hasReplied == true ||
                (request.auth.uid == get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initiatorId && get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initialMessageCount < 5) ||
                (request.auth.uid != get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initiatorId && get(/databases/$(database)/documents/direct_chats/$(chatId)).data.hasReplied == false)
            )
        );
      }
    }
    match /support_tickets/{ticketId} {
      allow list: if hasRole(['admin', 'ghost', 'staff', 'support']);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }


    // --- 6. 后台管理模块 (KYC, 收款, 工单) ---
    match /paymentChangeRequests/{reqId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdminGroup();
        allow list: if isAdminGroup();
    }
    match /proApplications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminGroup());
      allow list: if isAdminGroup();
      allow update: if isAdminGroup();
      allow delete: if hasRole(['admin', 'ghost']);
    }

    // --- 默认兜底 ---
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
