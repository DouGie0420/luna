
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? getUserData().role : 'guest';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isGhost() {
      return getUserRole() == 'ghost';
    }

    function isStaff() {
      // A ghost is also staff
      return getUserRole() == 'staff' || isGhost() || isAdmin();
    }

    function isSupport() {
      return getUserRole() == 'support' || isStaff(); // isStaff already includes admin and ghost
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      // Anyone can read a user's public profile.
      allow get: if true;
      // Admins/Ghosts can list all users. Others can list if needed for specific queries (e.g. search) but with restrictions.
      allow list: if isAdmin() || isGhost() || true;
      
      // A user can create their own profile document.
      allow create: if isOwner(userId) && request.resource.data.role == 'guest';

      // Admins/Ghosts can perform updates on other users, with restrictions.
      allow update: if (isAdmin() || (isGhost() && resource.data.role != 'admin' && resource.data.role != 'ghost')) && request.auth.uid != userId;
      
      // A user can update their own profile, with specific rules for what can be changed.
      allow update: if isOwner(userId) &&
          // 1. Fields that a user can NEVER change directly.
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt', 'creditScore', 'creditLevel', 'lunarSoil', 'salesCount', 'purchasesCount', 'followersCount', 'followingCount']) == false &&
          
          // 2. Special rule for 'role': can only change from guest to user.
          (request.resource.data.role == resource.data.role || (resource.data.role == 'guest' && request.resource.data.role == 'user')) &&
          
          // 3. Special rule for 'kycStatus': user can only change from 'Not Verified' to 'Pending'.
          (request.resource.data.kycStatus == resource.data.kycStatus || (resource.data.kycStatus == 'Not Verified' && request.resource.data.kycStatus == 'Pending')) &&
          
          // 4. Special rule for 'postsCount': can only be incremented by 1.
          (request.resource.data.postsCount == resource.data.postsCount || request.resource.data.postsCount == resource.data.postsCount + 1);


      // Admins can delete anyone. Ghosts can delete anyone except other admins and ghosts.
      allow delete: if isAdmin() || (isGhost() && resource.data.role != 'admin' && resource.data.role != 'ghost');

      // User Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can view and list products.
      allow read, list: if true;
      // Any signed-in user can create a product, but must set themselves as the seller and include location.
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid && request.resource.data.location != null;
      
      // The original seller or staff can update a product. Location is immutable.
      allow update: if ( (resource.data.sellerId == request.auth.uid) || isStaff() ) 
                      && request.resource.data.location == resource.data.location;
      // Any signed-in user can increment views and searchHits.
      allow update: if isSignedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'searchHits']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits'])
      );
      
      allow delete: if (resource.data.sellerId == request.auth.uid) || isStaff();
    }
    
    // PROMOS (Managed by Staff/Admins/Ghosts)
    match /promos/{promoId} {
      // Anyone can view promotional content.
      allow read, list: if true;
      // Only staff and admins/ghosts can create or modify promos.
      allow write: if isStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       // get, update, delete can check resource.data for individual documents
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isAdmin() || isGhost();
       // list CANNOT check resource.data, so only admins or ghosts can list all orders.
       allow list: if isAdmin() || isGhost();
       // create checks request.resource.data
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       // Anyone can read reviews.
       allow read, list: if true;
       // Only the reviewer can create a review.
       allow create: if isOwner(request.resource.data.reviewerId);
       // Only the reviewer or an admin/ghost can modify/delete a review.
       allow update, delete: if isOwner(resource.data.reviewerId) || isAdmin() || isGhost();
    }

    // SUPPORT TICKETS (Managed by Support/Admins/Ghosts)
    match /supportTickets/{ticketId} {
        // get, update, delete can check resource.data for individual tickets
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isSupport();
        // list can only check request context, not individual documents
        allow list: if isSupport();
        // any signed-in user can create a ticket
        allow create: if isSignedIn();
    }

    // BBS Posts
    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid && request.resource.data.location != null;
      
      // Update rules:
      // 1. The author can update their post, but not the location or interaction counts.
      // 2. Any signed-in user can interact (like, favorite) or increment views/searchHits.
      allow update: if (isOwner(resource.data.authorId) 
                        && request.resource.data.location == resource.data.location
                        && request.resource.data.likes == resource.data.likes
                        && request.resource.data.favorites == resource.data.favorites
                        && request.resource.data.replies == resource.data.replies
                      ) 
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'favorites', 'likedBy', 'favoritedBy', 'views', 'searchHits']));
      
      allow delete: if resource.data.authorId == request.auth.uid || isAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        // Anyone can update likes/dislikes
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'dislikes', 'likedBy', 'dislikedBy']);
        allow delete: if resource.data.authorId == request.auth.uid || isAdmin();
      }
    }
  }
}
