rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Allow access if the user has an 'admin' role in their user document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS
    match /users/{userId} {
      // A user can read and write to their own document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can get and list all user documents.
      allow get, list: if isAdmin();
      // Admins can update the kycStatus field of any user.
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys.hasOnly(['kycStatus']);

      // Subcollections for users
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can read products.
      allow read: if true;
      // Users can create products if the seller ID matches their UID.
      allow create: if request.auth.uid == request.resource.data.seller.id;
      // Users can only update/delete their own products.
      allow update, delete: if request.auth.uid == resource.data.seller.id;
    }
    
    // NOTIFICATIONS
    match /notifications/{notificationId} {
      // Users can only read, update, or delete their own notifications.
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      // Admins can create notifications for any user.
      allow create: if isAdmin();
    }

    // PROMOS
    match /promos/{promoId} {
      // Anyone can read promotional content.
      allow read: if true;
      // Only admins can write to promos.
      allow write: if isAdmin();
    }

    // ORDERS & REVIEWS (basic auth for now)
    match /orders/{orderId} {
       allow read, write: if request.auth != null;
    }
    match /reviews/{reviewId} {
       allow read, write: if request.auth != null;
    }
  }
}
