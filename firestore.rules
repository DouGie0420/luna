rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 輔助函數 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // 修復版 getRole：增加對未登入狀態的保護，防止報錯
    function getRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'guest';
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      // 只有在登入狀態下才去校驗管理組權限 (admin/ghost/staff/support)
      return isSignedIn() && hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 1. 配置與全局資訊 ---
    match /configs/{configId} {
      allow read: if true; 
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost']); // 嚴格限制：staff和support無權修改系統設置
    }
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /promos/{promoId} {
        allow read: if true;
        allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- 商戶集合 (merchants) ---
    match /merchants/{merchantId} {
      allow get: if true;
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 
      allow write: if isAdminGroup();
    }

    // --- 2. 用戶集合 (users) ---
    match /users/{userId} {
      allow get: if true;
      
      // 嚴格鎖死最大抓取上限為 50 個文檔
      allow list: if ("limit" in request.query && request.query.limit <= 50) || isAdminGroup(); 

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if hasRole(['admin', 'ghost']);
      
      // ✅ 權限修復：嚴格限制 staff 和 support 不能修改用戶資料 (除了特定的公開計數器)
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        (request.auth.uid != userId && hasRole(['admin', 'ghost'])) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'followersCount', 'following', 'followingCount']))
      );

      match /notifications/{notificationId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /addresses/{addressId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId; 
      }
      match /lunarSoilLedger/{ledgerEntryId} { 
        allow read, write: if isSignedIn() && request.auth.uid == userId; 
      }
    }

    // --- 3. 內容集合 (products, bbs) ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.sellerId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'views'])) ||
        (request.resource.data.status == 'under_review' && resource.data.status == 'active')
      );
      match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    match /bbs/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || isAdminGroup()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'replies', 'views']))
      );

      match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdminGroup());
      }
    }

    // --- 4. 交易與訂單 (orders) ---
    match /orders/{orderId} {
      allow list: if isAdminGroup() || (isSignedIn() && ("limit" in request.query && request.query.limit <= 50));
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdminGroup());
      // ✅ 修復：staff 和 support 擁有訂單管理的全部權限，允許刪除
      allow delete: if isAdminGroup(); 
    }

    match /reviews/{reviewId} {
      allow get: if true;
      allow write: if isSignedIn() && (request.resource.data.reviewerId == request.auth.uid || isAdminGroup());
      allow list: if ("limit" in request.query && request.query.limit <= 50);
    }

    // --- 5. 聊天與支持 ---
    
    // ✅ 新增：專門為 ChatWindow 組件配置的訂單聊天集合
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        isAdminGroup()
      );
      
      match /messages/{messageId} {
        // 只有該聊天的買賣雙方或管理組可以讀取和發送消息
        allow read, create: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId ||
          request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
          isAdminGroup()
        );
        allow update, delete: if isAdminGroup(); // 只有管理員可以撤回/刪除消息
      }
    }

    match /direct_chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        // 使用 get 確保即便只讀取一條訊息，也能校驗父級對話的 participants
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/direct_chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    match /support_tickets/{ticketId} {
      allow list: if isAdminGroup();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminGroup());

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || isAdminGroup());
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }

    // --- 6. FCM 令牌管理 ---
    match /fcm_tokens/{userId} {
      // 用戶只能讀寫自己的FCM令牌
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // 管理員可以讀取所有FCM令牌
      allow read: if isAdminGroup();
    }

    // --- 7. USDT 交易記錄 ---
    match /usdt_transactions/{txId} {
      // 用戶可以創建自己的交易記錄
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // 用戶可以讀取自己的交易記錄
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // 管理員可以讀取所有交易記錄
      allow read: if isAdminGroup();
      // 交易記錄一旦創建不可修改（防止篡改）
      allow update, delete: if false;
    }

    // --- 8. 後台管理模組 ---
    match /paymentChangeRequests/{reqId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdminGroup();
    }
    match /proApplications/{applicationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminGroup());
      allow list, update: if isAdminGroup();
      // ✅ 修復：staff 和 support 擁有 KYC 申請的全部權限，允許刪除
      allow delete: if isAdminGroup();
    }

    // --- 8. 🏠 房屋租賃模組 (rentalProperties) ---
    match /rentalProperties/{propertyId} {
      allow read: if resource.data.status == 'active' || (isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdminGroup()));
      allow create: if isSignedIn() && 
                      request.resource.data.ownerId == request.auth.uid &&
                      (isAdminGroup() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isPro', false) == true);
      allow update, delete: if isSignedIn() && 
                              (request.auth.uid == resource.data.ownerId || isAdminGroup());
    }

    // --- 默認拒絕 ---
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}