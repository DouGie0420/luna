
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, list: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /notifications/{notiId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn(); 
      }
      
      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /bbs/{docId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }

    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    match /orders/{orderId} {
       // Allow a user to get their own order, either as a buyer or seller.
       allow get: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);

       // Allow a user to create an order for themselves.
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
       
       // Allow buyer or seller to update an order.
       allow update: if isSignedIn() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
    }

    // This is the crucial fix for the "My Purchases" page error.
    // It allows a user to LIST orders only if they are querying by their own buyerId.
    match /orders/{orderId} {
      allow list: if isSignedIn() && request.query.where.buyerId == request.auth.uid;
    }

    // Contextual comment rules
    match /products/{productId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /bbs/{postId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    match /reviews/{reviewId} {
       allow get, list: if true;
       allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
    }
  }
}
