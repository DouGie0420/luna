rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? getUserData().role : 'guest';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isGhost() {
      return getUserRole() == 'ghost';
    }

    function isStaff() {
      // A ghost is also staff
      return getUserRole() == 'staff' || isGhost() || isAdmin();
    }

    function isSupport() {
      return getUserRole() == 'support' || isStaff(); // isStaff already includes admin and ghost
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      // Anyone can read a user's public profile.
      allow get: if true;
      // Only admins or ghosts can list all users.
      allow list: if isAdmin() || isGhost();
      
      // A user can create their own profile document.
      allow create: if isOwner(userId) && request.resource.data.role == 'guest';

      // Admin/Ghost can perform updates.
      allow update: if isAdmin() || (isGhost() && resource.data.role != 'admin' && resource.data.role != 'ghost');
      
      // A user can update their own profile, with specific rules for different scenarios.
      allow update: if isOwner(userId) && (
        // SCENARIO A: Updating profile from the account settings page.
        (
          // Ensures only fields from the profile form are being changed.
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'gender', 'location', 'bio', 'kycStatus', 'kycIdPhotoUrl', 'kycSelfieUrl', 'photoURL', 'isNftVerified']) &&
          // Ensures user cannot change their own core stats during a profile save.
          request.resource.data.creditScore == resource.data.creditScore &&
          request.resource.data.creditLevel == resource.data.creditLevel &&
          request.resource.data.postsCount == resource.data.postsCount &&
          // Ensures a valid KYC status transition (Not Verified -> Pending).
          (resource.data.kycStatus == 'Not Verified' && request.resource.data.kycStatus == 'Pending' || request.resource.data.kycStatus == resource.data.kycStatus)
        )
        ||
        // SCENARIO B: System action to increment post count after creating a post.
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postsCount']) &&
          request.resource.data.postsCount == resource.data.postsCount + 1
        )
      );

      // Admins can delete anyone. Ghosts can delete anyone except other admins and ghosts.
      allow delete: if isAdmin() || (isGhost() && resource.data.role != 'admin' && resource.data.role != 'ghost');

      // User Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin() || isGhost();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can view and list products.
      allow read, list: if true;
      // Any signed-in user can create a product, but must set themselves as the seller and include location.
      allow create: if isSignedIn() && request.resource.data.seller.id == request.auth.uid && request.resource.data.location != null;
      
      // The original seller or staff can update a product. Location is immutable.
      allow update: if ( (resource.data.seller.id == request.auth.uid) || isStaff() ) 
                      && request.resource.data.location == resource.data.location;
      // Any signed-in user can increment views and searchHits.
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'searchHits']);
      
      allow delete: if (resource.data.seller.id == request.auth.uid) || isStaff();
    }
    
    // PROMOS (Managed by Staff/Admins/Ghosts)
    match /promos/{promoId} {
      // Anyone can view promotional content.
      allow read: if true;
      // Only staff and admins/ghosts can create or modify promos.
      allow write: if isStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       // get, update, delete can check resource.data for individual documents
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isAdmin() || isGhost();
       // list CANNOT check resource.data, so only admins or ghosts can list all orders.
       allow list: if isAdmin() || isGhost();
       // create checks request.resource.data
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       // Anyone can read reviews.
       allow read: if true;
       // Only the reviewer can create a review.
       allow create: if isOwner(request.resource.data.reviewerId);
       // Only the reviewer or an admin/ghost can modify/delete a review.
       allow update, delete: if isOwner(resource.data.reviewerId) || isAdmin() || isGhost();
    }

    // SUPPORT TICKETS (Managed by Support/Admins/Ghosts)
    match /supportTickets/{ticketId} {
        // get, update, delete can check resource.data for individual tickets
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isSupport();
        // list can only check request context, not individual documents
        allow list: if isSupport();
        // any signed-in user can create a ticket
        allow create: if isSignedIn();
    }

    // BBS Posts
    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid && request.resource.data.location != null;
      
      // Update rules:
      // 1. The author can update their post, but not the location.
      // 2. Any signed-in user can interact (like, favorite) or increment views/searchHits.
      allow update: if (isOwner(resource.data.authorId) && request.resource.data.location == resource.data.location) 
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'favorites', 'likedBy', 'favoritedBy', 'views', 'searchHits']));
      
      allow delete: if resource.data.authorId == request.auth.uid || isAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn(); // Relies on frontend for granular control (likes/dislikes)
        allow delete: if resource.data.authorId == request.auth.uid || isAdmin();
      }
    }
  }
}
