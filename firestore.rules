rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return isSignedIn() ? getUserData().role : 'guest';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isStaff() {
      return getUserRole() == 'staff' || isAdmin();
    }

    function isSupport() {
      return getUserRole() == 'support' || isStaff() || isAdmin();
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      allow read: if true;
      
      // An admin can update any field.
      // A user can update their own profile, but cannot change their own role,
      // EXCEPT for promoting themselves from 'guest' to 'user' after their email is verified.
      allow update: if isAdmin() || (isOwner(userId) && (
                      request.resource.data.role == resource.data.role ||
                      (resource.data.role == 'guest' && resource.data.emailVerified == true && request.resource.data.role == 'user')
                    ));

      // A user can create their own profile, but must have the 'guest' role initially.
      allow create: if isOwner(userId) && request.resource.data.role == 'guest';
      
      allow delete: if isAdmin(); // Only admins can delete user documents.

      // User Subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /lunarSoilLedger/{ledgerEntryId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{notificationId} {
        // Users can only access their own notifications.
        allow read, write: if isOwner(userId);
      }
    }

    // PRODUCTS
    match /products/{productId} {
      // Anyone can view products.
      allow read: if true;
      // Any signed-in user can create a product, but must set themselves as the seller.
      allow create: if isSignedIn() && request.resource.data.seller.id == request.auth.uid;
      // Only the original seller or staff/admin can update/delete a product.
      allow update, delete: if (resource.data.seller.id == request.auth.uid) || isStaff();
    }
    
    // PROMOS (Managed by Staff/Admins)
    match /promos/{promoId} {
      // Anyone can view promotional content.
      allow read: if true;
      // Only staff and admins can create or modify promos.
      allow write: if isStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       // get, update, delete can check resource.data
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isAdmin();
       // list CANNOT check resource.data, so only admins can list all orders.
       allow list: if isAdmin();
       // create checks request.resource.data
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       // Anyone can read reviews.
       allow read: if true;
       // Only the reviewer can create a review.
       allow create: if isOwner(request.resource.data.reviewerId);
       // Only the reviewer or an admin can modify/delete a review.
       allow update, delete: if isOwner(resource.data.reviewerId) || isAdmin();
    }

    // SUPPORT TICKETS (Managed by Support/Admins)
    match /supportTickets/{ticketId} {
        // get, update, delete can check resource.data for individual tickets
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isSupport();
        // list can only check request context, not individual documents
        allow list: if isSupport();
        // any signed-in user can create a ticket
        allow create: if isSignedIn();
    }
  }
}
