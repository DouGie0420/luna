rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 辅助函数 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    // 判断是否属于你的四级管理组
    function isAdminGroup() {
      return hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 订单集合 (orders) 修复逻辑 ---
    match /orders/{orderId} {
      
      // 1. 列表查询 (list)：必须与前端 array-contains 查询完全对应
      // 解决了“我买到的”页面报错
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      // 2. 单文档读取 (get)：允许参与者或管理组查看
      allow get: if isSignedIn() && (
        request.auth.uid in resource.data.participants || isAdminGroup()
      );

      // 3. 写入权限
      allow create: if isSignedIn();
      allow update, delete: if isAdminGroup();
    }

    // --- 用户集合 (users) ---
    match /users/{userId} {
      allow read: if isSignedIn();
      
      // 只有 admin 和 ghost 可以修改/删除管理组信息
      allow update, delete: if isSignedIn() && (
        request.auth.uid == userId || hasRole(['admin', 'ghost'])
      );

      match /notifications/{notifId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isAdminGroup();
      }

      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- 其他后台管理模块 (KYC, 收款, 工单) ---
    // 你的定义：staff 和 support 拥有这些模块的全部权限
    match /kyc_applications/{appId} { allow read, write: if isAdminGroup(); }
    match /paymentChangeRequests/{reqId} { allow read, write: if isAdminGroup(); }
    match /supportTickets/{ticketId} { allow read, write: if isAdminGroup(); }

    // --- 内容管理 (社区, 广告, 问题) ---
    // 你的定义：staff 有权限，support 无权限
    match /bbs/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
    }
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- 评论子集合规则 ---
    match /bbs/{postId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
     match /products/{productId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // --- 默认兜底 ---
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin']);
    }
  }
}
