rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 辅助函数 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      return hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 订单集合 (orders) ---
    match /orders/{orderId} {
      
      // Admins can list all orders for the backend pages.
      // Users can perform queries constrained by the 'get' rule.
      allow list: if isAdminGroup();
      
      // Users can get their own orders, Admins can get any order.
      allow get: if isSignedIn() && (
        request.auth.uid in resource.data.participants || isAdminGroup()
      );

      // Only signed in users can create an order.
      allow create: if isSignedIn();
      
      // Only admins can update or delete an order.
      allow update, delete: if isAdminGroup();
    }

    // --- 用户集合 (users) ---
    match /users/{userId} {
      allow read: if true;
      allow list: if true; // Allow public listing of users for features like "Verified Merchants".
      
      allow delete: if isSignedIn() && (
        request.auth.uid == userId || hasRole(['admin', 'ghost'])
      );

      allow update: if isSignedIn() && (
        hasRole(['admin', 'ghost']) ||
        (
          !('role' in request.resource.data && request.resource.data.role != resource.data.role) &&
          !('kycStatus' in request.resource.data && request.resource.data.kycStatus != resource.data.kycStatus) &&
          !('isPro' in request.resource.data && request.resource.data.isPro != resource.data.isPro) &&
          !('creditScore' in request.resource.data && request.resource.data.creditScore != resource.data.creditScore) &&
          !('creditLevel' in request.resource.data && request.resource.data.creditLevel != resource.data.creditLevel)
        )
      );

      match /notifications/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- 其他后台管理模块 (KYC, 收款, 工单) ---
    match /kyc_applications/{appId} { allow read, write: if isAdminGroup(); }
    match /paymentChangeRequests/{reqId} {
      allow list: if isAdminGroup();
      allow get, create, update, delete: if isAdminGroup();
    }
    match /supportTickets/{ticketId} {
      allow list: if isAdminGroup();
      allow get, create, update, delete: if isAdminGroup();
    }

    // --- 内容管理 (社区, 广告, 问题) ---
    match /bbs/{postId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- 默认兜底 ---
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin']);
    }
  }
}
