
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 辅助函数 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(roles) {
      return isSignedIn() && getRole() in roles;
    }

    function isAdminGroup() {
      return hasRole(['admin', 'ghost', 'staff', 'support']);
    }

    // --- 订单集合 (orders) ---
    match /orders/{orderId} {
      allow list: if isAdminGroup();
      allow get: if isSignedIn() && (
        request.auth.uid in resource.data.participants || isAdminGroup()
      );
      allow create: if isSignedIn();
      allow update, delete: if isAdminGroup();
    }

    // --- 用户集合 (users) ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if hasRole(['admin', 'ghost']);

      allow update: if isSignedIn() && (
        // Case 1: Updating own profile, but cannot change own role
        (request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        // Case 2: Admin/Ghost can update anything
        hasRole(['admin', 'ghost']) ||
        // Case 3: Following/Unfollowing another user.
        (request.auth.uid != userId && request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'followersCount', 'following', 'followingCount']))
      );

      match /notifications/{docId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /addresses/{addressId} {
        allow read, list: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // --- Chat Systems ---
    match /direct_chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn() && request.query.limit <= 50; // Requires where clause in client
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && get(/databases/$(database)/documents/direct_chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId && (
            // User must be a participant to send a message
            request.auth.uid in get(/databases/$(database)/documents/direct_chats/$(chatId)).data.participants &&
            (
                // Case A: Friends can always chat
                get(/databases/$(database)/documents/direct_chats/$(chatId)).data.isFriendMode == true ||
                // Case B: Receiver has replied
                get(/databases/$(database)/documents/direct_chats/$(chatId)).data.hasReplied == true ||
                // Case C: Receiver hasn't replied, but sender is the initiator and under the limit
                (
                    request.auth.uid == get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initiatorId &&
                    get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initialMessageCount < 5
                ) ||
                // Case D: Receiver is replying for the first time
                (
                    request.auth.uid != get(/databases/$(database)/documents/direct_chats/$(chatId)).data.initiatorId &&
                    get(/databases/$(database)/documents/direct_chats/$(chatId)).data.hasReplied == false
                )
            )
        );
      }
    }

    match /support_tickets/{ticketId} {
      allow list: if hasRole(['admin', 'ghost', 'staff', 'support']);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn() && (request.auth.uid == resource.data.userId || hasRole(['admin', 'ghost', 'staff', 'support']));

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      }
    }


    // --- 其他后台管理模块 (KYC, 收款, 工单) ---
    match /paymentChangeRequests/{reqId} {
      allow read, list, create, update, delete: if isAdminGroup();
    }

    // --- 内容管理 (社区, 广告, 问题) ---
    match /bbs/{postId} {
      allow get: if true;
      allow list: if resource.data.status == 'active' || (request.auth != null);
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      allow update: if isSignedIn() && (
        // Authors and admins can edit anything
        (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff'])) ||
        // Any user can update interaction fields
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'replies', 'views']))
      );

       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      }
    }
    match /products/{productId} {
      allow get: if true;
      allow list: if resource.data.status == 'active' || (request.auth != null);
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      allow update: if isSignedIn() && (
        // Seller and admins can edit anything
        (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff'])) ||
        // Any user can update interaction fields
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'favorites', 'favoritedBy', 'views']))
      );
       match /comments/{commentId} {
          allow read, list: if true;
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
      }
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if hasRole(['admin', 'ghost', 'staff']);
    }
    match /promos/{promoId} {
        allow read: if true;
        allow write: if hasRole(['admin', 'ghost', 'staff']);
    }

    // --- 默认兜底 ---
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin']);
    }
  }
}
