
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check for multiple roles safely.
    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role IN roles;
    }

    match /users/{userId} {
      allow get: if true;
      // User can edit self. Admin can edit anyone. Ghost can edit anyone but Admin.
      // Staff cannot edit user profiles from the admin panel, as per user instruction.
      allow write: if (isSignedIn() && request.auth.uid == userId) || 
                     hasRole(['admin']) || 
                     (hasRole(['ghost']) && resource.data.role != 'admin');

      match /notifications/{notiId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn(); // For server-side functions
      }
      
      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /bbs/{postId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      // Author can update/delete. staff, ghost, admin can too.
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
    }

    match /products/{productId} {
      allow read, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || hasRole(['admin', 'ghost', 'staff']));
    }

    match /orders/{orderId} {
       allow get: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || hasRole(['admin', 'support']));
       allow list: if isSignedIn() && (request.query.buyerId == request.auth.uid || hasRole(['admin', 'support']));
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
       allow update: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || hasRole(['admin', 'support']));
    }

    // Contextual comment rules
    match /products/{productId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /bbs/{postId}/comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    match /reviews/{reviewId} {
       allow get, list: if true;
       allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
    }

    match /paymentChangeRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));
      allow list: if isSignedIn() && (request.query.userId == request.auth.uid || hasRole(['admin', 'ghost', 'staff', 'support']));
      allow update: if hasRole(['admin', 'ghost', 'staff', 'support']);
    }
    
    match /supportTickets/{ticketId} {
        allow create: if isSignedIn();
        allow read, list, update: if hasRole(['admin', 'ghost', 'support']);
    }
  }
}
