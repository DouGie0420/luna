
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.get('role', 'guest');
    }

    function isRequestingUserAdmin() {
      return getUserRole(request.auth.uid) == 'admin';
    }
    
    function isRequestingUserGhost() {
        return getUserRole(request.auth.uid) == 'ghost';
    }

    function isRequestingUserStaff() {
        return getUserRole(request.auth.uid) in ['staff', 'ghost', 'admin', 'support'];
    }

    function isRequestingUserSupport() {
        return getUserRole(request.auth.uid) in ['support', 'staff', 'ghost', 'admin'];
    }
    
    // --- Collection Rules ---

    // USER PROFILES
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);

      allow update: if 
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletAddress', 'isWeb3Verified']) && resource.data.walletAddress == null && request.resource.data.isWeb3Verified == true)
        ||
        (isOwner(userId) && !isRequestingUserStaff() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt', 'creditScore', 'creditLevel', 'lunarSoil', 'rating', 'reviewsCount', 'salesCount', 'purchasesCount', 'role', 'followersCount', 'followingCount', 'postsCount', 'featuredCount', 'isPro', 'isWeb3Verified', 'isNftVerified', 'walletAddress']))
        ||
        (isOwner(userId) && resource.data.role == 'guest' && request.resource.data.role == 'user' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'emailVerified', 'lastLogin', 'displayName', 'photoURL']))
        ||
        (isOwner(userId) && (request.resource.data.followingCount == resource.data.followingCount + 1 || request.resource.data.followingCount == resource.data.followingCount - 1) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followingCount']))
        ||
        (isSignedIn() && (request.resource.data.followersCount == resource.data.followersCount + 1 || request.resource.data.followersCount == resource.data.followersCount - 1) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']))
        ||
        (isOwner(userId) && request.resource.data.postsCount == resource.data.postsCount + 1 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postsCount']))
        ||
        (isRequestingUserStaff() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt']) && (isRequestingUserAdmin() || !(getUserRole(userId) in ['admin', 'ghost'])));


      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isRequestingUserStaff();
      }
      
      match /notifications/{notificationId} {
          allow read, update: if isOwner(userId);
          allow create: if isSignedIn(); 
      }
      
      match /lunarSoilLedger/{ledgerId} {
        allow write: if isRequestingUserStaff();
      }
    }

    // PRODUCTS
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow delete: if isRequestingUserAdmin();
      
      allow update: if 
        (isRequestingUserStaff() && request.resource.data.diff(resource.data).affectedKeys().subsetOf(['status', 'reviewReason']).size() > 0) 
        ||
        (!isRequestingUserStaff() && isOwner(resource.data.sellerId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewReason', 'location', 'likes', 'favorites', 'views', 'searchHits', 'likedBy', 'favoritedBy', 'sellerId', 'createdAt', 'isWeb3Verified', 'walletAddress']))
        ||
        (isSignedIn() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'favoritedBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits'])
        ));
    }
    
    // PROMOS (Managed by Staff/Admins/Ghosts)
    match /promos/{promoId} {
      allow get, list: if true;
      allow write: if isRequestingUserStaff();
    }

    // ORDERS
    match /orders/{orderId} {
       allow get, update, delete: if (isSignedIn() && (request.auth.uid == resource.data.buyerId 
                         || request.auth.uid == resource.data.sellerId))
                         || isRequestingUserAdmin() || isRequestingUserGhost();
       allow list: if isRequestingUserAdmin() || isRequestingUserGhost();
       allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
       allow get, list: if true;
       allow create: if isOwner(request.resource.data.reviewerId);
       allow update, delete: if isOwner(resource.data.reviewerId) || isRequestingUserAdmin() || isRequestingUserGhost();
    }

    // SUPPORT TICKETS (Managed by Support/Admins/Ghosts)
    match /supportTickets/{ticketId} {
        allow get, update, delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isRequestingUserSupport();
        allow list: if isRequestingUserSupport();
        allow create: if isSignedIn();
    }

    // BBS Posts
    match /bbs/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn() 
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.author.id == request.auth.uid
                    && request.resource.data.location != null;
      allow delete: if isRequestingUserAdmin();

      allow update: if 
        (isRequestingUserStaff() && request.resource.data.diff(resource.data).affectedKeys().subsetOf(['status', 'isFeatured', 'reviewReason']).size() > 0)
        ||
        (!isRequestingUserStaff() && isOwner(resource.data.authorId) &&
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewReason', 'location', 'likes', 'favorites', 'likedBy', 'favoritedBy', 'replies', 'views', 'searchHits', 'isFeatured', 'authorId', 'createdAt']))
        ||
        (isSignedIn() && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'favoritedBy']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['searchHits']) ||
            (request.resource.data.replies == resource.data.replies + 1 &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']))
        ));

      // Comments subcollection
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'likedBy', 'dislikedBy']);
        allow delete: if isOwner(resource.data.authorId) || isRequestingUserAdmin();
      }
    }
  }
}
